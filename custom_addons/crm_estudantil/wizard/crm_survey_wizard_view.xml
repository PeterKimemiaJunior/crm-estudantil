<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_survey_wizard_form" model="ir.ui.view">
        <field name="name">crm.survey.wizard.form</field>
        <field name="model">crm.survey.wizard</field>
        <field name="arch" type="xml">
            <form string="Enviar Questionário">
                <group>
                    <field name="survey_id" widget="selection"/>
                    <field name="message" placeholder="Mensagem opcional a incluir no email..."/>
                </group>
                <group string="Candidatos Seleccionados">
                    <field name="lead_ids" nolabel="1" widget="many2many_tags" readonly="1"/>
                </group>
                <footer>
                    <button name="action_send_email" string="Enviar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_crm_survey_wizard" model="ir.actions.act_window">
        <field name="name">Enviar Questionário</field>
        <field name="res_model">crm.survey.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="crm.model_crm_lead"/>
        <field name="binding_view_types">list,form</field>
    </record>
</odoo>
