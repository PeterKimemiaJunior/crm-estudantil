<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_candidatura" model="ir.ui.view">
            <field name="name">Formulário Candidatura</field>
            <field name="type">qweb</field>
            <field name="key">page_candidatura</field>
            <field name="arch" type="xml">
                <t t-call="website.layout">
                <div class="o_websites_full">
                    <style>
                        :root { --primary: #0F4C81; --primary-light: #E6F1FB; --primary-dark: #042C53; --action: #1D9E75; --action-light: #E1F5EE; --action-dark: #0F6E56; --bg-page: #F2F4F7; --bg-card: #FFFFFF; --text-primary: #1A2B3C; --text-muted: #5A6475; --border: #DDE3EC; --estagio-bg: #E6F1FB; --estagio-tx: #0F4C81; --posgrad-bg: #EEEDFE; --posgrad-tx: #3C3489; --evento-bg: #FFF3DC; --evento-tx: #7A4F00; --suporte-bg: #EAF3DE; --suporte-tx: #27500A; --sidebar-w: 240px; --topbar-h: 60px; }
                        body { font-family: 'IBM Plex Sans', sans-serif; background: var(--bg-page); color: var(--text-primary); font-size: 15px; line-height: 1.6; margin: 0; padding: 0; }
                        .app { display: flex; min-height: 100vh; }
                        .sidebar { width: var(--sidebar-w); background: var(--primary-dark); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; height: 100vh; z-index: 100; border-right: 1px solid rgba(255,255,255,0.06); }
                        .sidebar-logo { padding: 20px 20px 16px; border-bottom: 1px solid rgba(255,255,255,0.08); }
                        .sidebar-logo .name { font-family: 'Source Serif 4', serif; font-size: 16px; font-weight: 600; color: #fff; letter-spacing: 0.01em; }
                        .sidebar-logo .sub { font-size: 11px; color: rgba(255,255,255,0.45); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 2px; }
                        .sidebar nav { padding: 12px 0; flex: 1; }
                        .nav-section { font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.3); padding: 16px 20px 6px; }
                        .nav-item { display: flex; align-items: center; gap: 10px; padding: 9px 20px; color: rgba(255,255,255,0.6); font-size: 13.5px; cursor: pointer; transition: all 0.15s; border-left: 3px solid transparent; text-decoration: none; }
                        .nav-item:hover { color: #fff; background: rgba(255,255,255,0.06); }
                        .nav-item.active { color: #fff; background: rgba(255,255,255,0.08); border-left-color: var(--action); font-weight: 500; }
                        .nav-icon { font-size: 15px; width: 18px; text-align: center; }
                        .nav-badge { margin-left: auto; background: var(--action); color: #fff; font-size: 10px; font-weight: 600; padding: 1px 6px; border-radius: 10px; }
                        .sidebar-user { padding: 14px 16px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; gap: 10px; }
                        .user-avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--action); color: #fff; font-size: 12px; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
                        .user-name { font-size: 12.5px; color: #fff; font-weight: 500; }
                        .user-role { font-size: 11px; color: rgba(255,255,255,0.4); }
                        .main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
                        .topbar { height: var(--topbar-h); background: var(--bg-card); border-bottom: 1px solid var(--border); display: flex; align-items: center; padding: 0 28px; gap: 16px; position: sticky; top: 0; z-index: 50; }
                        .topbar-title { font-family: 'Source Serif 4', serif; font-size: 18px; font-weight: 600; color: var(--primary); }
                        .topbar-right { margin-left: auto; display: flex; align-items: center; gap: 10px; }
                        .btn { display: inline-flex; align-items: center; gap: 6px; padding: 7px 16px; border-radius: 6px; font-size: 13px; font-weight: 500; cursor: pointer; border: 1px solid transparent; font-family: inherit; transition: all 0.15s; text-decoration: none; }
                        .btn-primary { background: var(--primary); color: #fff; }
                        .btn-primary:hover { background: var(--primary-dark); }
                        .btn-action { background: var(--action); color: #fff; }
                        .btn-action:hover { background: var(--action-dark); }
                        .btn-outline { background: transparent; border-color: var(--border); color: var(--text-primary); }
                        .btn-outline:hover { border-color: var(--primary); color: var(--primary); }
                        .page { padding: 28px; flex: 1; }
                        .form-page { max-width: 680px; }
                        .breadcrumb { font-size: 12px; color: var(--text-muted); margin-bottom: 20px; }
                        .breadcrumb a { color: var(--primary); text-decoration: none; }
                        .breadcrumb a:hover { text-decoration: underline; }
                        .context-banner { background: var(--primary-light); border-left: 4px solid var(--primary); border-radius: 0 8px 8px 0; padding: 14px 18px; margin-bottom: 24px; display: flex; align-items: center; gap: 16px; }
                        .context-banner .cb-title { font-size: 14px; font-weight: 600; color: var(--primary); }
                        .context-banner .cb-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
                        .form-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 28px; }
                        .form-card h2 { font-family: 'Source Serif 4', serif; font-size: 20px; color: var(--primary); margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
                        .form-section-label { font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); font-weight: 600; margin-bottom: 14px; margin-top: 24px; }
                        .form-row { display: flex; gap: 16px; }
                        .form-group { display: flex; flex-direction: column; gap: 5px; flex: 1; margin-bottom: 14px; }
                        .form-group label { font-size: 13px; font-weight: 500; color: var(--text-primary); }
                        .form-group input, .form-group select, .form-group textarea { padding: 9px 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 13.5px; font-family: inherit; color: var(--text-primary); background: var(--bg-card); outline: none; transition: border 0.15s; }
                        .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(15,76,129,0.08); }
                        .form-group textarea { resize: vertical; min-height: 110px; }
                        .radio-group { display: flex; gap: 10px; flex-wrap: wrap; padding-top: 4px; }
                        .radio-opt { display: flex; align-items: center; gap: 6px; padding: 6px 14px; border: 1px solid var(--border); border-radius: 20px; cursor: pointer; font-size: 13px; transition: all 0.15s; }
                        .radio-opt input { accent-color: var(--primary); }
                        .radio-opt:has(input:checked) { border-color: var(--primary); background: var(--primary-light); color: var(--primary); font-weight: 500; }
                        .upload-zone { border: 1.5px dashed var(--border); border-radius: 8px; padding: 24px; text-align: center; cursor: pointer; transition: all 0.15s; background: #FAFBFD; }
                        .upload-zone:hover { border-color: var(--primary); background: var(--primary-light); }
                        .upload-icon { font-size: 24px; margin-bottom: 8px; }
                        .upload-text { font-size: 13px; font-weight: 500; color: var(--text-primary); }
                        .upload-sub { font-size: 11.5px; color: var(--text-muted); margin-top: 3px; }
                        .checkbox-row { display: flex; align-items: flex-start; gap: 10px; margin-top: 8px; }
                        .checkbox-row input { margin-top: 3px; accent-color: var(--primary); flex-shrink: 0; }
                        .checkbox-row label { font-size: 12.5px; color: var(--text-muted); line-height: 1.5; }
                        .form-actions { display: flex; align-items: center; justify-content: space-between; margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border); }
                        .link-back { font-size: 13px; color: var(--primary); text-decoration: none; display: flex; align-items: center; gap: 4px; }
                        .link-back:hover { text-decoration: underline; }
                        .success-msg { display: none; background: var(--action-light); border: 1px solid var(--action); border-radius: 10px; padding: 20px 24px; text-align: center; margin-top: 20px; }
                        .success-msg.show { display: block; }
                        .success-icon { font-size: 32px; margin-bottom: 8px; }
                        .success-msg h3 { color: var(--action-dark); font-size: 15px; margin-bottom: 4px; }
                        .success-msg p { font-size: 13px; color: var(--text-muted); }
                        .badge-estagio { background: var(--estagio-bg); color: var(--estagio-tx); padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; letter-spacing: 0.02em; }
                    </style>

                    <div class="app">
                        <aside class="sidebar">
                            <div class="sidebar-logo"><div class="name">CRM Estudantil</div><div class="sub">Universidade Eduardo Mondlane</div></div>
                            <nav>
                                <div class="nav-section">Principal</div>
                                <a class="nav-item" href="/oportunidades"><span class="nav-icon">📋</span> Oportunidades</a>
                                <a class="nav-item" href="/kanban"><span class="nav-icon">🗂️</span> Pipeline CRM<span class="nav-badge">9</span></a>
                                <div class="nav-section">Estudante</div>
                                <a class="nav-item active" href="/candidatura"><span class="nav-icon">📝</span> Candidatar-se</a>
                                <a class="nav-item" href="/faq"><span class="nav-icon">💬</span> Suporte &amp; FAQ</a>
                                <div class="nav-section">Gestão</div>
                                <a class="nav-item" href="/dashboard"><span class="nav-icon">📧</span> Campanhas Email</a>
                                <a class="nav-item" href="/dashboard"><span class="nav-icon">📊</span> Questionários</a>
                            </nav>
                            <div class="sidebar-user"><div class="user-avatar">GA</div><div><div class="user-name">Dr. Mussa Abílio</div><div class="user-role">Gestor Académico</div></div></div>
                        </aside>
                        <div class="main">
                            <div class="topbar"><span class="topbar-title">Nova Candidatura</span>
                                <div class="topbar-right"><a href="/faq" class="btn btn-outline">💬 Suporte</a><a href="/oportunidades" class="btn btn-action">← Voltar</a></div>
                            </div>
                            <div class="page">
                                <div class="form-page">
                                    <div class="breadcrumb"><a href="/oportunidades">Home</a> › <a href="/oportunidades">Oportunidades</a> › Candidatura</div>
                                    <div class="context-banner"><span class="badge badge-estagio">Estágio</span><div><div class="cb-title">Estágio em Desenvolvimento Web — TechMoz Lda</div><div class="cb-sub">Prazo de candidatura: 30 de Maio de 2026</div></div></div>
                                    <div class="form-card">
                                        <h2>Formulário de Candidatura</h2>
                                        <div class="form-section-label">Dados Pessoais</div>
                                        <div class="form-group"><label>Nome Completo *</label><input type="text" placeholder="Ex: Ana Beatriz Machava"/></div>
                                        <div class="form-row"><div class="form-group"><label>Número de Estudante *</label><input type="text" placeholder="Ex: 20231234"/></div><div class="form-group"><label>Contacto (Telemóvel)</label><input type="text" placeholder="+258 84 000 0000"/></div></div>
                                        <div class="form-row"><div class="form-group"><label>Curso *</label><select><option value="">Selecciona o teu curso</option><option value="informatica">Engenharia Informática</option><option value="gestao">Gestão</option><option value="direito">Direito</option><option value="medicina">Medicina</option><option value="economia">Economia</option><option value="outro">Outro</option></select></div><div class="form-group"><label>Email Institucional *</label><input type="email" placeholder="nome@uem.ac.mz"/></div></div>
                                        <div class="form-group"><label>Ano Curricular *</label><div class="radio-group"><label class="radio-opt"><input type="radio" name="ano" value="1"/> 1.º Ano</label><label class="radio-opt"><input type="radio" name="ano" value="2"/> 2.º Ano</label><label class="radio-opt"><input type="radio" name="ano" value="3"/> 3.º Ano</label><label class="radio-opt"><input type="radio" name="ano" value="4"/> 4.º Ano</label><label class="radio-opt"><input type="radio" name="ano" value="5"/> 5.º Ano</label></div></div>
                                        <div class="form-section-label">Carta de Motivação</div>
                                        <div class="form-group"><label>Descreve a tua motivação *</label><textarea id="motiv-area" placeholder="Descreve a tua motivação, competências relevantes e o que esperas aprender nesta oportunidade..." oninput="updateCounter()"/><div style="text-align:right;font-size:11.5px;color:var(--text-muted);margin-top:4px;" id="char-count">0 / 1000 caracteres</div></div>
                                        <div class="form-section-label">Documentos</div>
                                        <div class="upload-zone" onclick="alert('Seleccionar ficheiro (simulado)')"><div class="upload-icon">📄</div><div class="upload-text">Arrasta o teu CV aqui ou clica para seleccionar</div><div class="upload-sub">PDF ou Word — máx. 5MB</div></div>
                                        <div class="checkbox-row" style="margin-top:16px;"><input type="checkbox" id="privacy-check"/><label for="privacy-check">Autorizo que os meus dados sejam partilhados com a entidade parceira para fins de recrutamento, nos termos da política de privacidade da UEM.</label></div>
                                        <div class="form-actions"><a href="/oportunidades" class="link-back">← Voltar às Oportunidades</a><button class="btn btn-action" style="padding:10px 24px;font-size:14px;" onclick="submitForm()">Enviar Candidatura</button></div>
                                        <div class="success-msg" id="success-msg"><div class="success-icon">✅</div><h3>Candidatura enviada com sucesso!</h3><p>A equipa da UEM irá analisar o teu pedido e contactar-te em breve por email institucional.</p></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <script>
                        function updateCounter() { const ta = document.getElementById('motiv-area'); document.getElementById('char-count').textContent = ta.value.length + ' / 1000 caracteres'; }
                        async function submitForm() {
                            const btn = document.querySelector('.btn-action');
                            const originalText = btn.textContent;
                            btn.textContent = 'A enviar...';
                            btn.disabled = true;

                            const formData = {
                                name: document.querySelector('input[placeholder*="Ana"]').value,
                                email: document.querySelector('input[placeholder*="uem.ac.mz"]').value,
                                phone: document.querySelector('input[placeholder*="84"]').value,
                                student_number: document.querySelector('input[placeholder*="2023"]').value,
                                course: document.querySelector('select').value,
                                year: document.querySelector('input[name="ano"]:checked')?.value,
                                opportunity_type: 'estagio', // Podes tornar isto dinâmico conforme a vaga clicada
                                motivation: document.getElementById('motiv-area').value
                            };

                            try {
                                const response = await fetch('/crm_estudantil/submit_lead', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({
                                        jsonrpc: '2.0',
                                        method: 'call',
                                        params: formData,
                                        id: 1
                                    })
                                });
                                const data = await response.json();

                                if (data.result?.success) {
                                    document.getElementById('success-msg').classList.add('show');
                                    document.querySelector('.form-actions').style.display = 'none';
                                    document.getElementById('success-msg').scrollIntoView({ behavior: 'smooth' });
                                } else {
                                    alert(data.result?.message || 'Erro ao enviar.');
                                }
                            } catch (err) {
                                alert('Erro de ligação. Verifica se o servidor está online.');
                            } finally {
                                btn.textContent = originalText;
                                btn.disabled = false;
                            }
                        }
                    </script>
                </div>
            </t>
        </field>
        </record>

<record id="page_candidatura" model="website.page">
            <field name="name">Nova Candidatura</field>
            <field name="url">/candidatura</field>
            <field name="website_published">True</field>
            <field name="view_id" ref="crm_estudantil.view_candidatura"/>            <field name="footer_visible">False</field>        </record>
    </data>
</odoo>