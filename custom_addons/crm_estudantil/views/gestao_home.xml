<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="page_gestao_home" name="Gestão — Home">
    <t t-call="crm_estudantil.crm_layout">
        <t t-set="active_menu" t-value="'home'"/>
        <t t-set="page_title" t-value="'Gestão — Painel'"/>

        <div class="grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-bottom:20px;">
            <div class="card" style="padding:18px;background:var(--bg-card);border:1px solid var(--border);border-radius:8px;">
                <div style="font-size:13px;color:var(--text-muted);">Total Oportunidades</div>
                <div style="font-size:22px;font-weight:700;color:var(--primary);"><t t-esc="total_opps"/></div>
                <div style="font-size:12px;color:var(--text-muted);">Ativas: <t t-esc="active_opps"/></div>
            </div>

            <div class="card" style="padding:18px;background:var(--bg-card);border:1px solid var(--border);border-radius:8px;">
                <div style="font-size:13px;color:var(--text-muted);">Total Candidaturas</div>
                <div style="font-size:22px;font-weight:700;color:var(--primary);"><t t-esc="total_cands"/></div>
                <div style="font-size:12px;color:var(--text-muted);">Novas/Em análise/Aprovadas/Rejeitadas</div>
            </div>

            <div class="card" style="padding:18px;background:var(--bg-card);border:1px solid var(--border);border-radius:8px;">
                <div style="font-size:13px;color:var(--text-muted);">Resumo por Estágio</div>
                <div style="margin-top:8px;display:flex;flex-direction:column;gap:6px;">
                    <t t-foreach="stages_count.items()" t-as="pair">
                        <div style="display:flex;justify-content:space-between;font-size:13px;">
                            <span><t t-esc="pair[0]"/></span>
                            <span style="font-weight:700;color:var(--text-primary);"><t t-esc="pair[1]"/></span>
                        </div>
                    </t>
                </div>
            </div>
        </div>

        <div style="display:flex;gap:18px;">
            <div style="flex:1;background:var(--bg-card);border:1px solid var(--border);padding:18px;border-radius:8px;">
                <h3 style="margin-top:0;">Oportunidades Recentes</h3>
                <t t-if="recent_opps">
                    <ul style="list-style:none;padding:0;margin:0;">
                        <t t-foreach="recent_opps" t-as="op">
                            <li style="padding:10px 0;border-bottom:1px dashed var(--border);display:flex;justify-content:space-between;align-items:center;">
                                <div>
                                    <a t-attf-href="/gestao/oportunidades/#{op['id']}" style="font-weight:600;color:var(--primary);text-decoration:none;"><t t-esc="op['name']"/></a>
                                    <div style="font-size:12px;color:var(--text-muted);"> <t t-esc="op['company_name']"/> · <t t-esc="op['deadline']"/></div>
                                </div>
                                <div style="font-size:13px;color:var(--text-primary);font-weight:700;">👥 <t t-esc="op['total_candidaturas']"/></div>
                            </li>
                        </t>
                    </ul>
                </t>
                <t t-if="not recent_opps">
                    <div style="color:var(--text-muted);padding:20px;text-align:center;">Sem oportunidades recentes.</div>
                </t>
            </div>

            <div style="width:320px;background:var(--bg-card);border:1px solid var(--border);padding:18px;border-radius:8px;">
                <h4 style="margin-top:0;">Ações Rápidas</h4>
                <div style="display:flex;flex-direction:column;gap:8px;margin-top:10px;">
                    <a href="/gestao/oportunidades" class="btn btn-outline">Ver todas as oportunidades</a>
                    <a href="/gestao/criar-oportunidade" class="btn btn-action">Criar nova oportunidade</a>
                    <a href="/gestao/candidaturas" class="btn btn-outline">Ver Kanban de candidaturas</a>
                </div>
            </div>
        </div>

    </t>
</template>

</data>
</odoo>
