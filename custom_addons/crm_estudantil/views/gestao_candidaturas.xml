<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="page_gestao_candidaturas" name="Gestão de Candidaturas">
            <t t-call="website.layout">
                <div class="o_websites_full">
                    <style>
                        .gestao-container { max-width: 1400px; margin: 0 auto; padding: 40px 20px; }
                        .stats-bar { display: flex; gap: 15px; margin-bottom: 30px; flex-wrap: wrap; }
                        .stat-box { background: white; border: 1px solid #DDE3EC; border-radius: 8px; padding: 15px 20px; flex: 1; min-width: 120px; text-align: center; }
                        .stat-box .number { font-size: 28px; font-weight: bold; color: #0F4C81; }
                        .stat-box .label { font-size: 12px; color: #5A6475; margin-top: 5px; }
                        .kanban-board { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
                        .kanban-column { background: #F2F4F7; border-radius: 10px; padding: 15px; min-height: 400px; }
                        .kanban-header { font-weight: 600; color: #1A2B3C; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #DDE3EC; padding-bottom: 10px; }
                        .candidatura-card { background: white; border: 1px solid #DDE3EC; border-radius: 8px; padding: 15px; margin-bottom: 12px; transition: all 0.2s; }
                        .candidatura-card:hover { box-shadow: 0 4px 12px rgba(15,76,129,0.15); transform: translateY(-2px); }
                        .card-header { display: flex; justify-content: space-between; align-items: start; margin-bottom: 8px; }
                        .card-name { font-weight: 600; font-size: 14px; color: #1A2B3C; }
                        .card-type { font-size: 10px; padding: 2px 8px; border-radius: 10px; background: #E6F1FB; color: #0F4C81; white-space: nowrap; }
                        .card-info { font-size: 12px; color: #5A6475; margin: 4px 0; }
                        .card-actions { margin-top: 12px; padding-top: 12px; border-top: 1px solid #F2F4F7; display: flex; gap: 5px; flex-wrap: wrap; }
                        .btn-move { padding: 5px 10px; font-size: 11px; border-radius: 4px; border: none; cursor: pointer; color: white; font-weight: 500; transition: opacity 0.2s; }
                        .btn-move:hover { opacity: 0.85; }
                        .btn-analise { background: #534AB7; }
                        .btn-aprovar { background: #1D9E75; }
                        .btn-rejeitar { background: #D85A30; }
                        .btn-voltar { background: #5A6475; }
                        @media (max-width: 1024px) { .kanban-board { grid-template-columns: repeat(2, 1fr); } }
                        @media (max-width: 640px) { .kanban-board { grid-template-columns: 1fr; } }
                    </style>
                    <div class="gestao-container">
                        <h1 style="font-family: 'Source Serif 4', serif; color: #0F4C81; margin-bottom: 20px;">📊 Gestão de Candidaturas</h1>
                        
                        <div class="stats-bar">
                            <div class="stat-box"><div class="number" t-esc="total">0</div><div class="label">Total</div></div>
                            <div class="stat-box"><div class="number" t-esc="len(stages['novo'])">0</div><div class="label">Novos</div></div>
                            <div class="stat-box"><div class="number" t-esc="len(stages['analise'])">0</div><div class="label">Em Análise</div></div>
                            <div class="stat-box"><div class="number" t-esc="len(stages['aprovado'])">0</div><div class="label">Aprovados</div></div>
                            <div class="stat-box"><div class="number" t-esc="len(stages['rejeitado'])">0</div><div class="label">Rejeitados</div></div>
                        </div>

                        <div class="kanban-board">
                            <!-- Coluna: Novo -->
                            <div class="kanban-column">
                                <div class="kanban-header"><span>📥 Novo</span><span t-esc="len(stages['novo'])">0</span></div>
                                <t t-foreach="stages['novo']" t-as="lead">
                                    <div class="candidatura-card" t-att-data-id="lead.id">
                                        <div class="card-header">
                                            <span class="card-name" t-esc="lead.contact_name">Nome</span>
                                            <span class="card-type" t-esc="dict(lead._fields['opportunity_type'].selection).get(lead.opportunity_type, lead.opportunity_type)">Tipo</span>
                                        </div>
                                        <div class="card-info"><strong>Nº Estudante:</strong> <span t-esc="lead.student_number">-</span></div>
                                        <div class="card-info"><strong>Curso:</strong> <span t-esc="dict(lead._fields['course'].selection).get(lead.course, lead.course) or '-'">-</span></div>
                                        <div class="card-info"><strong>Data:</strong> <span t-esc="lead.create_date.strftime('%d/%m/%Y')">-</span></div>
                                        <div class="card-actions">
                                            <button class="btn-move btn-analise" onclick="moveLead(this, 'analise')">→ Análise</button>
                                            <button class="btn-move btn-aprovar" onclick="moveLead(this, 'aprovado')">✓ Aprovar</button>
                                            <button class="btn-move btn-rejeitar" onclick="moveLead(this, 'rejeitado')">✗ Rejeitar</button>
                                        </div>
                                    </div>
                                </t>
                            </div>

                            <!-- Coluna: Em Análise -->
                            <div class="kanban-column">
                                <div class="kanban-header"><span>🔍 Em Análise</span><span t-esc="len(stages['analise'])">0</span></div>
                                <t t-foreach="stages['analise']" t-as="lead">
                                    <div class="candidatura-card" t-att-data-id="lead.id">
                                        <div class="card-header">
                                            <span class="card-name" t-esc="lead.contact_name">Nome</span>
                                            <span class="card-type" t-esc="dict(lead._fields['opportunity_type'].selection).get(lead.opportunity_type, lead.opportunity_type)">Tipo</span>
                                        </div>
                                        <div class="card-info"><strong>Nº Estudante:</strong> <span t-esc="lead.student_number">-</span></div>
                                        <div class="card-actions">
                                            <button class="btn-move btn-aprovar" onclick="moveLead(this, 'aprovado')">✓ Aprovar</button>
                                            <button class="btn-move btn-rejeitar" onclick="moveLead(this, 'rejeitado')">✗ Rejeitar</button>
                                        </div>
                                    </div>
                                </t>
                            </div>

                            <!-- Coluna: Aprovado -->
                            <div class="kanban-column">
                                <div class="kanban-header"><span>✅ Aprovado</span><span t-esc="len(stages['aprovado'])">0</span></div>
                                <t t-foreach="stages['aprovado']" t-as="lead">
                                    <div class="candidatura-card" t-att-data-id="lead.id">
                                        <div class="card-header">
                                            <span class="card-name" t-esc="lead.contact_name">Nome</span>
                                        </div>
                                        <div class="card-info"><strong>Nº Estudante:</strong> <span t-esc="lead.student_number">-</span></div>
                                        <div class="card-actions">
                                            <button class="btn-move btn-voltar" onclick="moveLead(this, 'novo')">↺ Voltar</button>
                                        </div>
                                    </div>
                                </t>
                            </div>

                            <!-- Coluna: Rejeitado -->
                            <div class="kanban-column">
                                <div class="kanban-header"><span>❌ Rejeitado</span><span t-esc="len(stages['rejeitado'])">0</span></div>
                                <t t-foreach="stages['rejeitado']" t-as="lead">
                                    <div class="candidatura-card" t-att-data-id="lead.id">
                                        <div class="card-header">
                                            <span class="card-name" t-esc="lead.contact_name">Nome</span>
                                        </div>
                                        <div class="card-info"><strong>Nº Estudante:</strong> <span t-esc="lead.student_number">-</span></div>
                                        <div class="card-actions">
                                            <button class="btn-move btn-voltar" onclick="moveLead(this, 'novo')">↺ Voltar</button>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>

                    <script>
                        function moveLead(btn, stage) {
                            const card = btn.closest('.candidatura-card');
                            const leadId = card.getAttribute('data-id');
                            btn.disabled = true;
                            btn.style.opacity = '0.5';
                            
                            fetch('/api/candidaturas/move', {
                                method: 'POST',
                                headers: {'Content-Type': 'application/json'},
                                body: JSON.stringify({
                                    jsonrpc: '2.0',
                                    method: 'call',
                                    params: {lead_id: leadId, target_stage: stage},
                                    id: 1
                                })
                            })
                            .then(res => res.json())
                            .then(data => {
                                if (data.result &amp;&amp; data.result.success) {
                                    location.reload();
                                } else {
                                    alert('Erro ao mover: ' + (data.result ? data.result.message : 'Falha na comunicação'));
                                    btn.disabled = false;
                                    btn.style.opacity = '1';
                                }
                            })
                            .catch(() => {
                                alert('Erro de conexão com o servidor');
                                btn.disabled = false;
                                btn.style.opacity = '1';
                            });
                        }
                    </script>
                </div>
            </t>
        </template>
    </data>
</odoo>